<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_bubble_wrap"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingStart="48dp"
    android:paddingEnd="0dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/layout_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_vet"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Tag e.g. "More info requested" -->
        <TextView
            android:id="@+id/tv_bubble_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_tag_vet"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- Message body -->
        <TextView
            android:id="@+id/tv_bubble_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_bubble_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="#AAAAAA"
        android:textSize="10sp" />

</LinearLayout>