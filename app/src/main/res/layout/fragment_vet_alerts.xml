<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0">

    <!-- Green Header Section -->
    <View
        android:id="@+id/view_header"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/header_green"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_alerts_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:text="Send Disease Alert"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_alerts_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Notify farmers of outbreak in region"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_alerts_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="@color/header_green" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="This alert will be sent to ALL farmers in the selected districts. Use only when a confirmed outbreak is detected."
                        android:textColor="@color/header_green"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Alert Details"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Disease / Outbreak Type"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_disease_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Enter disease name (e.g. Anthrax, FMD)"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Select Affected Districts"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- District Selection (Checkboxes) -->
            <GridLayout
                android:id="@+id/gl_districts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <CheckBox android:id="@+id/cb_maseru" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Maseru" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_leribe" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Leribe" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_berea" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Berea" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_mafeteng" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Mafeteng" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_mohale" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Mohale's Hoek" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_quthing" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Quthing" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_qacha" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Qacha's Nek" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_mokhotlong" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Mokhotlong" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_thaba" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Thaba-Tseka" android:textColor="@color/black" />
                <CheckBox android:id="@+id/cb_butha" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Butha-Buthe" android:textColor="@color/black" />
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Alert Message"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_alert_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_bg"
                android:gravity="top"
                android:hint="Compose your message..."
                android:minLines="4"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send_alert"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:text="Send Alert to Farmers"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/header_green"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>